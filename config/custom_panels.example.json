        {"idx": 3, "marker": "ACTA2", "role": "regional_area", "areaMinAreaUm2": 20.0, "expectedCompartments": ["fibrotic", "stromal"], "qcColor": "green"},
        {"idx": 4, "marker": "COL1A1", "role": "regional_area", "areaMinAreaUm2": 20.0, "expectedCompartments": ["fibrotic", "stromal"], "qcColor": "white"}
      ],
      "classify": []
    },
    "RED2KRAS_PROLIFERATION": {
      "label": "Red2-KrasG12D mutant-clone proliferation/state research",
      "channels": [
        {"idx": 1, "marker": "DAPI", "role": "nuclear", "qcColor": "blue"},
        {"idx": 2, "marker": "Red2Kras", "areaMarker": true, "areaMode": "reporter", "areaMinAreaUm2": 8.0, "expectedCompartments": ["alveolar", "tumor"], "qcColor": "red"},
        {"idx": 3, "marker": "Ki-67", "expectedCompartments": ["alveolar", "tumor"], "qcColor": "green"},
        {"idx": 4, "marker": "SOX9", "expectedCompartments": ["alveolar", "tumor"], "qcColor": "white"}
      ],
      "classify": [
        {"Red2Kras": true},
        {"Red2Kras": true, "Ki-67": true},
        {"Red2Kras": true, "SOX9": true}
      ]
    },
    "LUAD_LINEAGE": {
      "label": "Pulmonary adenocarcinoma lineage-support research",
      "channels": [
        {"idx": 1, "marker": "DAPI", "role": "nuclear", "qcColor": "blue"},
        {"idx": 2, "marker": "NKX2-1", "expectedCompartments": ["tumor"], "qcColor": "green"},
        {"idx": 3, "marker": "NAPSA", "expectedCompartments": ["tumor"], "qcColor": "red"},
        {"idx": 4, "marker": "EPCAM", "expectedCompartments": ["tumor"], "qcColor": "white"}
