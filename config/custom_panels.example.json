{
  "schema_version": "1.0.0",
  "notes": [
    "Examples are research templates, not validated biological cutoffs or diagnostic panels.",
    "Channel idx values must be changed to match the acquisition metadata.",
    "Copy this file outside the repository, keep only the panels you use, and set IFQ_PANEL_CONFIG to that copy.",
    "Derive fixed intensity thresholds and morphology settings from study controls before confirmatory analysis.",
    "The Red2Kras reporter areaMinAreaUm2 value is a placeholder example and must be validated for the acquisition resolution, section thickness, and clone endpoint."
  ],
  "panels": {
    "ARI_DATP": {
      "label": "Acute injury alveolar transitional-state research",
      "channels": [
        {"idx": 1, "marker": "DAPI", "role": "nuclear", "qcColor": "blue"},
        {"idx": 2, "marker": "KRT8", "expectedCompartments": ["alveolar"], "qcColor": "red"},
        {"idx": 3, "marker": "CLDN4", "expectedCompartments": ["alveolar"], "qcColor": "green"},
        {"idx": 4, "marker": "SFTPC", "expectedCompartments": ["alveolar"], "qcColor": "white"}
      ],
      "classify": [
        {"KRT8": true, "CLDN4": true},
        {"KRT8": true, "CLDN4": true, "SFTPC": false}
      ]
    },
    "IPF_BASALOID": {
      "label": "Fibrotic epithelial state research",
      "channels": [
        {"idx": 1, "marker": "DAPI", "role": "nuclear", "qcColor": "blue"},
        {"idx": 2, "marker": "KRT17", "expectedCompartments": ["fibrotic"], "qcColor": "red"},
        {"idx": 3, "marker": "KRT5", "expectedCompartments": ["fibrotic"], "qcColor": "green"},
        {"idx": 4, "marker": "TP63", "expectedCompartments": ["fibrotic"], "qcColor": "white"}
      ],
      "classify": [
        {"KRT17": true, "KRT5": false},
        {"KRT17": true, "TP63": true}
      ]
    },
    "IPF_STROMA": {
      "label": "Fibrotic stromal and matrix area research",
