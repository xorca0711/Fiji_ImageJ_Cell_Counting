{
  "schema_version": "1.0.0",
  "title": "Universal lung IF marker registry",
  "scope": "Research-oriented marker metadata for lung lineage, repair, fibrosis, vascular, immune, and tumor-lineage imaging. It is not a diagnostic classifier.",
  "source_note": "Structured from the user-supplied Lung_Cell_Lineages_Markers_Reference.pdf (7 pages) and the primary sources listed in docs/UNIVERSAL_MARKER_CONFIGURATION.md.",
  "role_templates": {
    "nuclear": "Segmentation channel only",
    "nuc_marker": "Connected signal within the DAPI nucleus plus nuclear enrichment",
    "nuc_ratio": "Nuclear signal relative to a cytoplasmic reference ring; normally single-plane",
    "cyto": "Connected signal in a nucleus-associated cytoplasmic support ring",
    "membrane": "Connected thin or circumferential signal in a local membrane-support ring",
    "apical_cilia": "Apical ciliary patches and optional nucleus-proximity association",
    "regional_area": "Thresholded regional structure area; no per-nucleus positive/negative call"
  },
  "research_profiles": {
    "acute_injury_regeneration": {
      "questions": [
        "AT2 to transitional to AT1 repair trajectory",
        "Airway-derived basal or secretory contribution",
        "Resolution versus persistence of transitional states"
      ],
      "marker_sets": [
        ["KRT8", "CLDN4", "SFTPC", "AGER"],
        ["KRT5", "TP63", "SCGB1A1", "AcTub"],
        ["IL1R1", "SFTPC", "KRT8", "PDPN"]
      ],
      "caveat": "KRT8 is broadly epithelial. A repair-state interpretation needs alveolar context and co-markers; time after injury is part of the phenotype."
    },
    "ipf_fibrosis": {
      "questions": [
        "Aberrant basaloid or transitional epithelial states",
        "Loss or remodeling of AT1 and AT2 compartments",
        "Pathogenic myofibroblast and matrix expansion"
      ],
      "marker_sets": [
        ["KRT17", "KRT5", "TP63", "ITGB6"],
        ["KRT8", "CLDN4", "SFTPC", "AGER"],
        ["CTHRC1", "ACTA2", "COL1A1", "PDGFRA"]
      ],
      "caveat": "KRT17-positive/KRT5-negative or KRT8-high patterns are state descriptions, not stand-alone IPF diagnoses. Fibrotic geography and orthogonal pathology are required."
    },
    "lung_adenocarcinoma_lineage": {
      "questions": [
        "Pulmonary glandular lineage support",
        "Tumor versus adjacent normal epithelial geography",
        "Adenocarcinoma versus squamous-lineage marker pattern"
      ],
      "marker_sets": [
        ["NKX2-1", "NAPSA", "EPCAM", "KRT7"],
        ["NKX2-1", "NAPSA", "TP63", "KRT5"]
      ],
      "caveat": "The image pipeline quantifies marker patterns; it does not diagnose malignancy or determine tumor origin. TTF-1/NKX2-1 and Napsin A require histomorphology, controls, and clinical-pathology review."
    }
  },
